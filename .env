# Environment variables for local development
# Fill these in with your real values when needed.

# Example: public site base URL (used in meta tags, etc.)
SITE_BASE_URL=http://localhost:5500

# Example: email address for contact form notifications (if you add backend/email)
CONTACT_EMAIL=you@example.com

# Example: any API key you might add later
API_KEY=your-api-key-here

